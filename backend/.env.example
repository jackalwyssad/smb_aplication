# Server Configuration
PORT=3001
NODE_ENV=development

# JWT Secret (ganti dengan string acak yang panjang dan aman)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=30d

# SFTP Default Settings (opsional, bisa diisi dari form login)
# SFTP_HOST=192.168.1.100
# SFTP_PORT=22
# SFTP_USERNAME=user
# SFTP_PASSWORD=password

# Keamanan
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS - Origin frontend (sesuaikan dengan port Vite)
CORS_ORIGIN=http://localhost:5173
